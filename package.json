{
  "name": "changer",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch server/index.js",
    "dev:web": "vite --config client/vite.config.js --host 0.0.0.0",
    "start": "node server/index.js",
    "build": "vite build --config client/vite.config.js",
    "preview": "vite preview --config client/vite.config.js --host 0.0.0.0",
    "db:migrate": "node server/scripts/migrate.js",
    "db:seed": "node server/scripts/seed.js",
    "db:seed:if-empty": "node server/scripts/seed-if-empty.js",
    "db:seed:admin": "node server/scripts/seed-admin.js",
    "db:import:second-year": "node server/scripts/import-second-year.js",
    "deploy:init": "npm run db:migrate && npm run db:seed:if-empty && npm run db:seed:admin",
    "db:reset": "npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.468.0",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.12",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^7.1.7"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
